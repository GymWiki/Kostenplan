# Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"

# Supabase dashboard -> "Connect" button -> "Session pooler" tab.
# Use the pooler host (contains "pooler.supabase.com"), not the direct
# "db.<project-ref>.supabase.co" host — that one is IPv6-only and will fail
# to connect from IPv4-only networks (most CI/local setups).
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Mollie (https://my.mollie.com/dashboard/developers/api-keys) — the API key
# itself is set directly in the Vercel dashboard, not committed here.
# MOLLIE_API_KEY="test_..."
#
# Vaste, publieke callback-URL waar Mollie betaal-/abonnementsupdates naartoe
# POST't (zie app/api/mollie/webhook/route.ts). Moet de productie-URL zijn,
# niet een per-deploy preview-URL — anders kan Mollie de webhook niet meer
# bereiken zodra de preview-deployment verdwijnt.
# MOLLIE_WEBHOOK_URL="https://www.kostenplan.nl/api/mollie/webhook"

# IndexNow (zie app/api/indexnow/route.ts): pingt Bing/Yandex/Naver/Seznam/
# Yep met de sitemap-URL's na elke productie-deploy (.github/workflows/
# indexnow.yml). INDEXNOW_KEY is bewust GEEN geheim — moet exact overeenkomen
# met de inhoud én bestandsnaam van public/<key>.txt, dat is hoe IndexNow
# domein-eigenaarschap verifieert. Bij het roteren van de key dus altijd
# beide tegelijk aanpassen.
# INDEXNOW_KEY="<32-karakter-hex-string, zie public/<key>.txt>"
#
# INDEXNOW_TRIGGER_SECRET is wél geheim: beschermt de route tegen misbruik
# door willekeurige aanroepers (die anders IndexNow-quota konden opmaken).
# Zelfde waarde ook als repo-secret in GitHub Actions instellen.
# INDEXNOW_TRIGGER_SECRET="<willekeurige lange random string>"
