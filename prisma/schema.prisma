// Prisma schema for Kostenplan
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ServicePrijsType {
  UURTARIEF
  VASTE_PRIJS
}

enum ArbeidStapEenheid {
  UUR
  DAGDEEL
  DAG
}

enum ExtraOptionType {
  PER_EENHEID
  PER_STUK
}

// Bepaalt welke features ontgrendeld zijn — zie app/lib/subscription.ts
// effectiveTier() voor hoe dit samen met User.overrideTier wordt bepaald.
enum SubscriptionTier {
  GRATIS
  PLUS
  PRO
}

enum BillingInterval {
  MAANDELIJKS
  JAARLIJKS
}

// Mirrort Mollie's eigen subscription-statussen 1-op-1 (zie
// @mollie/api-client SubscriptionStatus) om vertaalfouten in de
// webhook-verwerking te voorkomen. GEEN = er is nog nooit een Mollie-
// abonnement geweest (bijv. een Gratis-tenant die nooit heeft betaald).
enum MollieSubscriptionStatus {
  GEEN
  PENDING
  ACTIVE
  CANCELED
  SUSPENDED
  COMPLETED
}

enum Lettertype {
  MODERN
  KLASSIEK
  VRIENDELIJK
  STOER
}

enum ContactPositie {
  BOVENAAN
  ONDERAAN
}

// Doorloopt de pipeline van links (NIEUW) naar rechts (GEWONNEN/VERLOREN) op
// het Kanban-board in /dashboard/leads.
enum LeadStatus {
  NIEUW
  IN_BEHANDELING
  OFFERTE_VERSTUURD
  GEWONNEN
  VERLOREN
}

// id matches auth.users.id from Supabase Auth — the profile row is created
// right after a successful sign-up (see app/lib/actions/auth.ts).
model User {
  id               String            @id
  email            String            @unique
  bedrijfsnaam     String
  slug             String            @unique
  // Het abonnement zoals Mollie-webhooks het bijhouden — zie effectiveTier().
  subscriptionTier SubscriptionTier  @default(GRATIS)
  // Handmatige override — uitsluitend via Supabase Studio (Table editor of
  // SQL Editor) te zetten, nooit via de app-UI, en nooit door de
  // Mollie-webhook aangepast. Heeft absolute voorrang op subscriptionTier.
  // Zet dit bijv. op PRO om iemand (support, demo, VIP-klant) volledig
  // toegang te geven ongeacht hun daadwerkelijke betaalstatus:
  //   update "User" set "overrideTier" = 'PRO' where email = '...';
  // Terugzetten naar het echte, betaalde abonnement: zet het veld op NULL.
  overrideTier     SubscriptionTier?

  // Mollie-koppeling. mollieCustomerId wordt aangemaakt bij de eerste
  // checkout-poging; mollieSubscriptionId pas zodra de eerste betaling is
  // geslaagd en er een doorlopend abonnement is aangemaakt.
  mollieCustomerId     String?                  @unique
  mollieSubscriptionId String?                  @unique
  subscriptionStatus   MollieSubscriptionStatus @default(GEEN)
  billingInterval      BillingInterval?
  // Informatief: wanneer Mollie de eerstvolgende/laatst bekende
  // termijnbetaling verwacht (subscription.nextPaymentDate).
  huidigePeriodeEind   DateTime?

  // Onboarding-checklist op het dashboard (zie app/lib/onboarding.ts). De
  // eerste twee stappen (bedrijfsgegevens, eerste catalogusitem) worden
  // live afgeleid van bestaande data — nooit hier apart opgeslagen, dat zou
  // stale kunnen raken (bijv. als iemand hun enige product weer verwijdert).
  // "Portaal bekeken" heeft geen natuurlijk databaseer-spoor (een publiek,
  // anoniem bezoek), dus die stap wordt hier wél expliciet vastgelegd zodra
  // de link vanuit het dashboard wordt aangeklikt. onboardingVoltooid is de
  // permanente vlag die de widget voorgoed verbergt zodra alle stappen ooit
  // tegelijk voltooid zijn geweest.
  onboardingPortaalBekeken Boolean @default(false)
  onboardingVoltooid       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  costSettings CostSettings?
  branding     Branding?
  services     Service[]
  products     Product[]
  leads        Lead[]
}

// White-label/personalisatie-instellingen voor het klantenportaal. Los van
// CostSettings (dat gaat over prijslogica, dit over uitstraling en copy).
model Branding {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Publieke URL van een logo in Supabase Storage. Optioneel — zonder logo
  // toont het portaal het standaard Kostenplan-merkteken.
  logoUrl String?

  // Kleuren en lettertype: alleen te wijzigen/tonen op Plus/Pro (zie
  // effectiveTier() in app/lib/subscription.ts en updateBrandingAction voor
  // de server-side afdwinging). Gratis-tenants houden altijd de
  // Kostenplan-standaardkleuren en het standaardlettertype, ongeacht wat
  // hier is opgeslagen (bijv. na een downgrade).
  primaireKleur    String     @default("#15803d")
  achtergrondKleur String     @default("#f7faf8")
  lettertype       Lettertype @default(MODERN)

  // Content & copywriting — beschikbaar op alle tiers. "{bedrijfsnaam}" in
  // customTitel wordt vervangen door User.bedrijfsnaam.
  customTitel   String?
  welkomstTekst String?
  bedankTekst   String  @default("Bedankt voor uw aanvraag! Wij nemen binnen 24 uur contact met u op.")

  // Bedrijfsgegevens tonen — beschikbaar op alle tiers.
  toonTelefoonnummer Boolean        @default(false)
  telefoonnummer     String?
  toonEmail          Boolean        @default(false)
  contactPositie     ContactPositie @default(BOVENAAN)

  updatedAt DateTime @updatedAt
}

model CostSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Arbeidskosten — geldt alleen voor Producten (arbeidsCapaciteit). Diensten
  // hebben hun eigen uurtarief/vaste projectprijs, los van deze instelling.
  arbeidEnabled          Boolean           @default(true)
  arbeidZichtbaar        Boolean           @default(true)
  arbeidStapEenheid      ArbeidStapEenheid @default(UUR)
  arbeidTarief           Float             @default(45)
  // Als true mag elk product een eigen Product.arbeidTariefOverride hebben
  // die dit tarief vervangt.
  arbeidTariefPerProduct Boolean           @default(false)

  // Transportkosten — alleen aan/uit en zichtbaarheid; het bedrag wordt per
  // product ingesteld (Product.transportkosten) en hier opgeteld.
  transportEnabled   Boolean @default(true)
  transportZichtbaar Boolean @default(true)

  // Voorrijkosten
  voorrijEnabled   Boolean @default(true)
  voorrijZichtbaar Boolean @default(true)
  voorrijTarief    Float   @default(35)

  // Materiaalkosten — geldt alleen voor Producten. Diensten hebben geen
  // materiaalkosten meer.
  materiaalEnabled         Boolean @default(true)
  materiaalZichtbaar       Boolean @default(true)
  materiaalMarge           Float   @default(0)
  // Als true mag elk product een eigen Product.materiaalMargeOverride
  // hebben die deze opslag vervangt.
  materiaalMargePerProduct Boolean @default(false)

  btwPercentage Float @default(21)

  updatedAt DateTime @updatedAt
}

// Een dienst (arbeid), bijv. "Terrastegels leggen". In tegenstelling tot een
// Product (fysieke eigenschappen, schaalt met een hoeveelheid) draait een
// Dienst om arbeid: de klant vinkt hem simpelweg aan/uit in het
// klantenportaal, voor óf een uurtarief × geschat aantal uren, óf één vaste
// projectprijs.
model Service {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  naam          String
  omschrijving  String?
  prijsType     ServicePrijsType @default(UURTARIEF)
  // Bij UURTARIEF: kostprijs = uurtarief × geschatteUren.
  uurtarief     Float            @default(0)
  geschatteUren Float            @default(0)
  // Bij VASTE_PRIJS: kostprijs = vastePrijs, ongeacht uren.
  vastePrijs    Float            @default(0)
  // Naam van een lucide-react icoon uit app/lib/icons.ts, bijv. "Sprout".
  // Optioneel, puur decoratief.
  icoon         String?
  actief        Boolean          @default(true)
  order         Int              @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Een samengesteld product, bijv. "Schutting". De klant kiest een
// hoeveelheid, een materiaal per materiaalcategorie (bijv. "Palen") en
// eventueel extra opties.
model Product {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  naam                   String
  omschrijving           String?
  eenheid                String  @default("m1")
  // Aantal eenheden dat in één arbeidsstap (zie CostSettings.arbeidStapEenheid)
  // geplaatst kan worden, bijv. 5 (m1 schutting per dagdeel). Leeg betekent
  // dat dit product geen arbeidstijd kost.
  arbeidsCapaciteit      Float?
  // Vervangt CostSettings.arbeidTarief voor dit product, maar alleen als
  // CostSettings.arbeidTariefPerProduct aanstaat. Leeg = gebruik het tarief
  // uit Kosteninstellingen.
  arbeidTariefOverride   Float?
  // Vervangt CostSettings.materiaalMarge voor dit product, maar alleen als
  // CostSettings.materiaalMargePerProduct aanstaat. Leeg = gebruik de opslag
  // uit Kosteninstellingen.
  materiaalMargeOverride Float?
  // Vast transportbedrag voor dit product. Wordt, als het product een
  // hoeveelheid > 0 heeft, één keer meegeteld (niet vermenigvuldigd met de
  // hoeveelheid) en samen met die van andere geselecteerde producten
  // opgeteld tot één transporttotaal.
  transportkosten        Float   @default(0)
  // Naam van een lucide-react icoon uit app/lib/icons.ts, bijv. "Fence".
  // Optioneel, puur decoratief.
  icoon                  String?
  actief                 Boolean @default(true)
  order                  Int     @default(0)

  materiaalCategorieen MaterialCategory[]
  extraOpties          ExtraOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Onderdeel van een product waarvoor de klant één materiaal kiest,
// bijv. "Palen" of "Tussenbekleding" binnen het product "Schutting".
model MaterialCategory {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  naam  String
  order Int    @default(0)

  materialen MaterialOption[]

  createdAt DateTime @default(now())
}

// Een keuzeoptie binnen een materiaalcategorie, bijv. "Betonnen palen".
// De prijs is per eenheid van het bijbehorende product.
model MaterialOption {
  id                 String           @id @default(cuid())
  materialCategoryId String
  materialCategory   MaterialCategory @relation(fields: [materialCategoryId], references: [id], onDelete: Cascade)

  naam        String
  prijs       Float   @default(0)
  // Wordt verkocht per veelvoud van deze hoeveelheid (in de eenheid van het
  // product), bijv. 1.8 voor een paal die per 1,8 m wordt ingekocht. Leeg
  // betekent doorlopend geprijsd, zonder afronding.
  stapgrootte Float?
  // Publieke URL van een foto in Supabase Storage. Optioneel.
  foto        String?
  actief      Boolean @default(true)
  order       Int     @default(0)

  createdAt DateTime @default(now())
}

// Optionele toevoeging op een product, bijv. "Metalen tussenbekleding
// voor planten". Bij PER_EENHEID vinkt de klant de optie aan en telt hij
// mee met de hoeveelheid van het product (prijs per eenheid). Bij
// PER_STUK geeft de klant een eigen aantal op, los van de hoeveelheid
// van het product (prijs per stuk).
model ExtraOption {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  naam         String
  omschrijving String?
  prijs        Float           @default(0)
  type         ExtraOptionType @default(PER_EENHEID)
  // Publieke URL van een foto in Supabase Storage. Optioneel.
  foto         String?
  actief       Boolean         @default(true)
  order        Int             @default(0)

  createdAt DateTime @default(now())
}

// Een offerte-aanvraag vanuit het publieke klantenportaal — de mini-CRM voor
// de vakman op /dashboard/leads. Alleen aangemaakt door createLeadAction
// (zie app/lib/actions/leads.ts), en alleen als de tenant Plus/Pro is (zie
// effectiveTier() in app/lib/subscription.ts) — dit is dezelfde gate als de
// "Offerte aanvragen"-knop zelf op het portaal.
model Lead {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  naam           String
  email          String
  telefoonnummer String?

  status LeadStatus @default(NIEUW)

  // Bevroren op het moment van aanvragen — wat de consument had aangevinkt
  // en welke prijsindicatie daarbij hoorde. Los van de huidige Diensten/
  // Producten van de tenant, die intussen gewijzigd of verwijderd kunnen
  // zijn. Vorm: zie LeadSnapshot in app/lib/leads.ts.
  snapshot        Json
  // Los uit snapshot.totaal getrokken zodat de Pipeline Waarde-KPI zonder
  // JSON-parsing op de database kan optellen/filteren.
  totaalIndicatie Float

  notities LeadNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
}

// Individuele, los bewerkbare/verwijderbare aantekening bij een Lead (zie
// LeadDetailDrawer).
model LeadNote {
  id     String @id @default(cuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  tekst String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
